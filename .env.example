# Broker credentials (required only for live mode)
GROWW_API_KEY=
GROWW_API_SECRET=
GROWW_TOKEN_MODE=approval
GROWW_ACCESS_TOKEN=
GROWW_TOTP=
GROWW_APP_ID=
BROKER_PROVIDER=mock
BROKER_BASE_URL=https://api.groww.in
# Fail-closed live trading safety lock (keep disabled until explicit go-live)
LIVE_ORDER_EXECUTION_ENABLED=0
LIVE_ORDER_FORCE_ACK=
MARKET_DATA_PROVIDER=auto
GROWW_HISTORICAL_EXCHANGE=NSE
GROWW_HISTORICAL_SEGMENT=CASH
GROWW_HISTORICAL_INTERVAL=1day
GROWW_HISTORICAL_CHUNK_DAYS=170
RECONCILIATION_ENFORCE_CLOSE=0
RECONCILIATION_LOOKBACK_DAYS=30
GO_LIVE_MIN_SHARPE=0.7
GO_LIVE_MAX_DRAWDOWN=0.15
GO_LIVE_MIN_WIN_RATE=0.5
GO_LIVE_MIN_PROFIT_FACTOR=0.0
GO_LIVE_MIN_CLOSED_TRADES=10
GO_LIVE_MAX_CRITICAL_ERRORS=0
GO_LIVE_CRITICAL_WINDOW_DAYS=14
GO_LIVE_PROFILE=auto
ADAPTIVE_GO_LIVE_MIN_SHARPE=0.7
ADAPTIVE_GO_LIVE_MAX_DRAWDOWN=0.15
ADAPTIVE_GO_LIVE_MIN_WIN_RATE=0.30
ADAPTIVE_GO_LIVE_MIN_PROFIT_FACTOR=1.20
ADAPTIVE_GO_LIVE_MIN_CLOSED_TRADES=3
ADAPTIVE_GO_LIVE_MAX_CRITICAL_ERRORS=0
ADAPTIVE_GO_LIVE_CRITICAL_WINDOW_DAYS=14
AUDIT_TREND_LOOKBACK=8
RETENTION_DAYS=30
RETENTION_ARCHIVE_ROOT=archive
RETENTION_SOURCES=logs,reports/audits,reports/promotion,reports/rollback,reports/incidents,reports/retention
PAPER_RUN_REQUIRED_WEEKS=4
ADAPTIVE_PAPER_RUN_REQUIRED_WEEKS=6
PAPER_RUN_REQUIRE_PROMOTION_BUNDLE=1
AUTO_RESUME_ENABLED=1
AUTO_RESUME_INTERVAL_SECONDS=60
AUTO_RESUME_PREMARKET_START=08:00
AUTO_RESUME_PREMARKET_CUTOFF=10:00
AUTO_RESUME_MARKET_OPEN_START=09:15
AUTO_RESUME_MARKET_OPEN_CUTOFF=11:30
AUTO_RESUME_MARKET_CLOSE_START=15:30
AUTO_RESUME_MARKET_CLOSE_CUTOFF=21:00

# Telegram (optional in paper mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# sqlite by default
DATABASE_URL=sqlite:///trading_bot.db

ENVIRONMENT=paper
STARTING_CAPITAL=100000

# Strategy/risk profile (baseline | tuned_momentum_v2 | tuned_momentum_v3 | tuned_momentum_v4 | tuned_momentum_v5 | tuned_momentum_v6)
STRATEGY_PROFILE=baseline
ENABLE_MOMENTUM_BREAKOUT=1
ENABLE_MEAN_REVERSION=1
ENABLE_SECTOR_ROTATION=1
ENABLE_ADAPTIVE_TREND=0
ENABLE_BEAR_REVERSAL=0
ENABLE_VOLATILITY_REVERSAL=0

# Risk overrides (optional)
MAX_PORTFOLIO_HEAT=0.12
MAX_POSITIONS=10
MAX_POSITION_SIZE=0.15
RISK_PER_TRADE=0.02
TOTAL_COST_PER_TRADE=0.00355
COST_PER_SIDE=0.001775
DAILY_LOSS_LIMIT=0.03
WEEKLY_LOSS_LIMIT=0.05
MAX_DRAWDOWN=0.15

# Momentum strategy overrides (optional)
MOMENTUM_LOOKBACK_PERIOD=20
MOMENTUM_MIN_HISTORY=60
MOMENTUM_VOLUME_MULTIPLIER=1.2
MOMENTUM_MIN_ROC=0.05
MOMENTUM_MAX_ATR_PCT=0.05
MOMENTUM_STOP_ATR_MULT=2.0
MOMENTUM_RR_RATIO=2.0
MOMENTUM_TIME_STOP_DAYS=10
MOMENTUM_TIME_STOP_MOVE_PCT=0.02
MOMENTUM_ENABLE_REGIME_FILTER=1
MOMENTUM_REGIME_SMA_PERIOD=50
MOMENTUM_REGIME_VOL_WINDOW=20
MOMENTUM_REGIME_MAX_ANNUAL_VOL=0.55
MAX_SIGNALS_PER_DAY=3
MIN_EXPECTED_EDGE_PCT=0.005
ADAPTIVE_DEFENSIVE_MODE_ENABLED=0
ADAPTIVE_DEFENSIVE_BREADTH_SMA_PERIOD=50
ADAPTIVE_DEFENSIVE_MIN_BREADTH=0.45
ADAPTIVE_DEFENSIVE_MIN_ELIGIBLE_SYMBOLS=20
ADAPTIVE_DEFENSIVE_MAX_SIGNALS_PER_DAY=3
ADAPTIVE_DEFENSIVE_MIN_EXPECTED_EDGE_PCT=0.005
ADAPTIVE_DEFENSIVE_ALLOW_MOMENTUM=1
ADAPTIVE_DEFENSIVE_ALLOW_MEAN_REVERSION=1
ADAPTIVE_DEFENSIVE_ALLOW_SECTOR_ROTATION=0
ADAPTIVE_DEFENSIVE_ALLOW_ADAPTIVE_TREND=1
ADAPTIVE_DEFENSIVE_ALLOW_BEAR_REVERSAL=1
ADAPTIVE_DEFENSIVE_ALLOW_VOLATILITY_REVERSAL=1

# Mean reversion strategy overrides (optional)
MEAN_REV_OVERSOLD_BUFFER=5.0
MEAN_REV_TREND_TOLERANCE=0.95
MEAN_REV_BB_ENTRY_MULT=1.01
MEAN_REV_VOLUME_CAP=2.5
MEAN_REV_STOP_BB_BUFFER=0.98
MEAN_REV_STOP_SMA_BUFFER=0.98
MEAN_REV_STOP_ATR_MULT=1.5
MEAN_REV_TARGET_GAIN_PCT=0.08
MEAN_REV_TIME_STOP_DAYS=7

# Bear reversal strategy overrides (optional)
BEAR_REV_RSI_PERIOD=14
BEAR_REV_RSI_OVERSOLD=30
BEAR_REV_RSI_REENTRY=35
BEAR_REV_TREND_SMA_PERIOD=50
BEAR_REV_TREND_BELOW_SMA_MULT=0.99
BEAR_REV_DROP_LOOKBACK_DAYS=5
BEAR_REV_MIN_DROP_PCT=0.04
BEAR_REV_MIN_VOLUME_RATIO=0.8
BEAR_REV_STOP_ATR_MULT=1.2
BEAR_REV_RR_RATIO=1.0
BEAR_REV_MAX_HOLD_DAYS=4

# Volatility reversal strategy overrides (optional)
VOL_REV_RSI_PERIOD=14
VOL_REV_RSI_REENTRY=35
VOL_REV_DROP_LOOKBACK_DAYS=3
VOL_REV_MIN_DROP_PCT=0.03
VOL_REV_VOL_SPIKE_MULT=1.2
VOL_REV_MIN_ATR_PCT=0.025
VOL_REV_TREND_SMA_PERIOD=20
VOL_REV_TREND_BELOW_SMA_MULT=1.0
VOL_REV_STOP_ATR_MULT=1.1
VOL_REV_RR_RATIO=1.0
VOL_REV_MAX_HOLD_DAYS=3

# Adaptive trend strategy overrides (optional)
ADAPTIVE_TREND_WEEKLY_EMA_SHORT=10
ADAPTIVE_TREND_WEEKLY_EMA_LONG=30
ADAPTIVE_TREND_WEEKLY_ATR_PERIOD=10
ADAPTIVE_TREND_WEEKLY_RSI_PERIOD=10
ADAPTIVE_TREND_MIN_WEEKLY_ROC=0.03
ADAPTIVE_TREND_MAX_WEEKLY_ROC=0.20
ADAPTIVE_TREND_MIN_WEEKLY_EMA_SPREAD_PCT=0.005
ADAPTIVE_TREND_MIN_TREND_CONSISTENCY=0.50
ADAPTIVE_TREND_MIN_EXPECTED_R_MULT=1.0
ADAPTIVE_TREND_STOP_ATR_MULT=1.5
ADAPTIVE_TREND_MAX_POSITIONS=5
ADAPTIVE_TREND_MAX_NEW_PER_WEEK=3
ADAPTIVE_TREND_MIN_HOLD_DAYS=5
ADAPTIVE_TREND_TIME_STOP_DAYS=30
ADAPTIVE_TREND_PROFIT_PROTECT_PCT=0.03
ADAPTIVE_TREND_PROFIT_TRAIL_ATR_MULT=0.8
ADAPTIVE_TREND_BREAKEVEN_GAIN_PCT=0.03
ADAPTIVE_TREND_BREAKEVEN_BUFFER_PCT=0.005
ADAPTIVE_TREND_REGIME_MIN_BREADTH=0.50
ADAPTIVE_TREND_REGIME_MAX_VOL=0.30
ADAPTIVE_TREND_ML_ENABLED=0

# Universe selection
# TRADING_UNIVERSE can be: midcap150 (Nifty Midcap 150) or empty for default
TRADING_UNIVERSE=
# Optional: path to a file with one symbol per line (no .NS). If set, overrides TRADING_UNIVERSE.
UNIVERSE_FILE=
